@model Sistema.RENACER.ViewModels.Citas.CitaDetalleViewModel
@{
    ViewData["Title"] = "Detalle de la cita";
    Layout = "_Layout";

    var fin = Model.FechaHora.AddMinutes(Model.DuracionMinutos);
    var estadoClase = Model.Estado switch
    {
        "Programada" => "badge bg-info text-dark",
        "Asistió"    => "badge-activo",
        "No asistió" => "badge bg-warning text-dark",
        "Cancelada"  => "badge-inactivo",
        "Reagendada" => "badge bg-secondary",
        _ => "badge bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="page-title"><i class="fas fa-calendar-day me-2"></i>Detalle de la cita</h2>
        <p class="page-subtitle">Información completa de la cita programada</p>
    </div>
    <span class="@estadoClase">@Model.Estado</span>
</div>

<div class="card-renacer" style="max-width:780px;">
    <div class="card-body p-4">
        <dl class="row mb-2">
            <dt class="col-sm-4">Paciente</dt>
            <dd class="col-sm-8"><strong>@Model.Paciente</strong></dd>

            <dt class="col-sm-4">Fecha</dt>
            <dd class="col-sm-8">@Model.FechaHora.ToString("dddd, dd 'de' MMMM 'de' yyyy")</dd>

            <dt class="col-sm-4">Horario</dt>
            <dd class="col-sm-8">@Model.FechaHora.ToString("HH:mm") - @fin.ToString("HH:mm") (@Model.DuracionMinutos min)</dd>

            <dt class="col-sm-4">Tipo de cita</dt>
            <dd class="col-sm-8">@Model.TipoCita</dd>

            <dt class="col-sm-4">Profesional</dt>
            <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Profesional) ? "Responsable del centro" : Model.Profesional)</dd>

            <dt class="col-sm-4">Observaciones</dt>
            <dd class="col-sm-8">@(Model.Observaciones ?? "—")</dd>

            <dt class="col-sm-4">Fecha de registro</dt>
            <dd class="col-sm-8">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>

        <div class="d-flex gap-2 mt-4 flex-wrap">
            @if (Model.Estado == "Programada")
            {
                if (ClaimsHelper.TienePermiso(User, "CITA_EDITAR"))
                {
                    <form id="d-atender" asp-action="CambiarEstado" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.IdCita" />
                        <input type="hidden" name="nuevoEstado" value="Asistió" />
                        <button type="button" class="btn btn-success"
                                onclick="confirmarAccion('¿Marcar como atendida?', 'd-atender')">
                            <i class="fas fa-check me-1"></i>Marcar como atendida
                        </button>
                    </form>
                }
                if (ClaimsHelper.TienePermiso(User, "CITA_CANCELAR"))
                {
                    <form id="d-cancelar" asp-action="CambiarEstado" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.IdCita" />
                        <input type="hidden" name="nuevoEstado" value="Cancelada" />
                        <button type="button" class="btn btn-outline-danger"
                                onclick="confirmarAccion('¿Cancelar la cita?', 'd-cancelar')">
                            <i class="fas fa-times me-1"></i>Cancelar cita
                        </button>
                    </form>
                }
            }
            <a href="@Url.Action("Index")" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>
</div>
