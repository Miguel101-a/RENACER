@model IEnumerable<Sistema.RENACER.ViewModels.Roles.RolViewModel>
@{
    ViewData["Title"] = "Roles";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="page-title"><i class="fas fa-shield-alt me-2"></i>Gestión de Roles</h2>
        <p class="page-subtitle">Define grupos de permisos para los usuarios</p>
    </div>
    <a href="@Url.Action("Crear")" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Nuevo rol
    </a>
</div>

<div class="card-renacer">
    <div class="card-body">
        <table id="tablaRoles" class="table table-hover table-renacer w-100">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Estado</th>
                    <th>Permisos asignados</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td><strong>@r.Nombre</strong></td>
                        <td>@(r.Descripcion ?? "—")</td>
                        <td>
                            <span class="@(r.Activo ? "badge-activo" : "badge-inactivo")">
                                @(r.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td>
                            @foreach (var codigo in r.CodigosPermisos.Take(6))
                            {
                                <span class="badge-permiso">@codigo</span>
                            }
                            @if (r.CodigosPermisos.Count > 6)
                            {
                                <span class="badge-permiso">+@(r.CodigosPermisos.Count - 6) más</span>
                            }
                            @if (!r.CodigosPermisos.Any())
                            {
                                <span class="text-muted small">Sin permisos</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="@Url.Action("Editar", new { id = r.IdRol })"
                                   class="btn btn-sm btn-outline-primary" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="@Url.Action("AsignarPermisos", new { id = r.IdRol })"
                                   class="btn btn-sm btn-outline-primary" title="Asignar permisos">
                                    <i class="fas fa-key"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaRoles').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                pageLength: 10
            });
        });
    </script>
}
