@model Sistema.RENACER.ViewModels.Roles.RolViewModel
@{
    ViewData["Title"] = "Editar rol";
    Layout = "_Layout";
}

<div class="mb-3">
    <h2 class="page-title"><i class="fas fa-edit me-2"></i>Editar rol</h2>
</div>

<div class="card-renacer" style="max-width:560px;">
    <div class="card-body p-4">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="IdRol" type="hidden" />

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-4 form-check">
                <input asp-for="Activo" class="form-check-input" />
                <label asp-for="Activo" class="form-check-label">Activo</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Guardar</button>
                <a href="@Url.Action("AsignarPermisos", new { id = Model.IdRol })" class="btn btn-outline-primary">
                    <i class="fas fa-key me-1"></i>Asignar permisos
                </a>
                <a href="@Url.Action("Index")" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-1"></i>Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
