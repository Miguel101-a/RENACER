@model Sistema.RENACER.ViewModels.Roles.AsignarPermisosViewModel
@{
    ViewData["Title"] = $"Permisos — {Model.NombreRol}";
    Layout = "_Layout";
    var categorias = Model.Permisos.GroupBy(p => p.Categoria).OrderBy(g => g.Key);
}

<div class="mb-3">
    <h2 class="page-title"><i class="fas fa-key me-2"></i>Permisos del rol: @Model.NombreRol</h2>
    <p class="page-subtitle">Marca los permisos que tendrá este rol y guarda los cambios.</p>
</div>

<div class="card-renacer">
    <div class="card-body p-4">
        <form asp-action="AsignarPermisos" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="IdRol" type="hidden" />
            <input asp-for="NombreRol" type="hidden" />

            @foreach (var grupo in categorias)
            {
                <h6 class="text-uppercase fw-bold mb-2 mt-3"
                    style="color:var(--renacer-primary);font-size:.75rem;letter-spacing:1px;">
                    @grupo.Key
                </h6>
                <div class="row g-2 mb-3">
                    @foreach (var p in grupo)
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="form-check p-2 rounded"
                                 style="background:@(p.Asignado ? "var(--renacer-success-bg)" : "transparent");
                                        border:1px solid @(p.Asignado ? "rgba(23,52,4,0.15)" : "var(--renacer-border)");
                                        transition:.2s;">
                                <input class="form-check-input" type="checkbox"
                                       name="PermisosSeleccionados"
                                       value="@p.IdPermiso"
                                       id="perm-@p.IdPermiso"
                                       @(p.Asignado ? "checked" : "") />
                                <label class="form-check-label" for="perm-@p.IdPermiso">
                                    <span class="badge-permiso">@p.Codigo</span><br />
                                    <small class="text-muted">@p.Nombre</small>
                                </label>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Guardar cambios
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-1"></i>Volver
                </a>
            </div>
        </form>
    </div>
</div>
