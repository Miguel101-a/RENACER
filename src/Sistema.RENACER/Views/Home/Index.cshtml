@model IEnumerable<Sistema.RENACER.ViewModels.Usuarios.UsuarioListaViewModel>
@using Sistema.RENACER.Helpers
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
    var nombre = ClaimsHelper.GetNombreCompleto(User);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title">Bienvenido/a, @nombre</h2>
        <p class="page-subtitle">@DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="metric-card">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="metric-label">Pacientes</div><div class="metric-value">0</div></div>
                <div class="metric-icon"><i class="fas fa-users"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="metric-card" style="border-left-color:var(--renacer-secondary);">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="metric-label">Citas hoy</div><div class="metric-value">0</div></div>
                <div class="metric-icon" style="color:var(--renacer-secondary);"><i class="fas fa-calendar-check"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="metric-card" style="border-left-color:var(--renacer-accent-yellow);">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="metric-label">Pendientes</div><div class="metric-value">0</div></div>
                <div class="metric-icon" style="color:var(--renacer-accent-yellow);"><i class="fas fa-clock"></i></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="metric-card" style="border-left-color:var(--renacer-secondary-dark);">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="metric-label">Por cobrar</div><div class="metric-value" style="font-size:1.4rem;">Bs. 0</div></div>
                <div class="metric-icon" style="color:var(--renacer-secondary-dark);"><i class="fas fa-dollar-sign"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="sprint-notice mb-4">
    <i class="fas fa-info-circle me-2"></i>
    <strong>Sprint 1 activo.</strong> Módulos disponibles: Gestión de usuarios, roles y permisos.
    Pacientes, citas, pagos y reportes estarán disponibles en sprints siguientes.
</div>

<div class="card-renacer">
    <div class="card-header d-flex align-items-center gap-2">
        <i class="fas fa-history"></i> Últimos accesos al sistema
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 table-renacer">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Nombre completo</th>
                        <th>Último acceso</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td><code>@u.NombreUsuario</code></td>
                            <td>@u.NombreCompleto</td>
                            <td>@(u.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="3" class="text-center text-muted py-3">Sin registros.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
