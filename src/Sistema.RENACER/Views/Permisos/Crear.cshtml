@model Sistema.RENACER.ViewModels.Permisos.PermisoCrearViewModel
@{
    ViewData["Title"] = "Nuevo permiso";
    Layout = "_Layout";
}

<div class="mb-3">
    <h2 class="page-title"><i class="fas fa-plus-circle me-2"></i>Nuevo permiso</h2>
</div>

<div class="card-renacer" style="max-width:560px;">
    <div class="card-body p-4">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Codigo" class="form-label"></label>
                <input asp-for="Codigo" class="form-control text-uppercase"
                       placeholder="Ej: PAC_CREAR" oninput="this.value=this.value.toUpperCase()" />
                <small class="text-muted">Solo mayúsculas, números y guión bajo. Sin espacios.</small>
                <span asp-validation-for="Codigo" class="text-danger small d-block"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-4">
                <label asp-for="Categoria" class="form-label"></label>
                <select asp-for="Categoria" asp-items="Model.Categorias" class="form-select">
                    <option value="">— Seleccione —</option>
                </select>
                <span asp-validation-for="Categoria" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Guardar</button>
                <a href="@Url.Action("Index")" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-1"></i>Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
