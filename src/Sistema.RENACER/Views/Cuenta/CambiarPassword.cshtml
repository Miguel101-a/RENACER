@model Sistema.RENACER.ViewModels.Cuenta.CambiarPasswordViewModel
@{
    ViewData["Title"] = "Cambiar contraseña";
    Layout = "_LayoutLogin";
}

<div class="login-container" style="max-width:480px;">
    <div class="login-logo"><img src="~/img/logo.jpg" alt="RENACER" /></div>
    <div class="login-card">
        <h1 class="login-title">Nueva contraseña</h1>

        @if (ViewData["UsuarioRecuperacion"] != null)
        {
            <div class="sprint-notice mb-3">
                <i class="fas fa-info-circle me-2"></i>
                <strong>Token generado para:</strong> @ViewData["UsuarioRecuperacion"]<br />
                <strong>Token:</strong> <code class="user-select-all">@Model.Token</code><br />
                <small class="text-muted">Entrega este token al usuario para que complete el cambio. Expira en 30 minutos.</small>
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="login-error">@Html.ValidationSummary(false)</div>
        }

        <form asp-action="CambiarPassword" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Token" type="hidden" />

            <div class="mb-3">
                <label asp-for="NuevaPassword" class="form-label"></label>
                <input asp-for="NuevaPassword" class="form-control" placeholder="Mínimo 8 caracteres, 1 mayúscula, 1 número" />
                <span asp-validation-for="NuevaPassword" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="ConfirmarPassword" class="form-label"></label>
                <input asp-for="ConfirmarPassword" class="form-control" placeholder="Repite la contraseña" />
                <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-login">
                <i class="fas fa-save me-2"></i>Guardar nueva contraseña
            </button>
        </form>
    </div>
    <div class="login-footer">Sistema RENACER &copy; 2026</div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
