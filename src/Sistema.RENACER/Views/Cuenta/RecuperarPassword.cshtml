@model Sistema.RENACER.ViewModels.Cuenta.RecuperarPasswordViewModel
@{
    ViewData["Title"] = "Recuperar contraseña";
    Layout = "_LayoutLogin";
}

<div class="login-container">
    <div class="login-logo">
        <img src="~/img/logo.jpg" alt="RENACER" />
    </div>
    <div class="login-card">
        <h1 class="login-title">Recuperar contraseña</h1>
        <p class="login-subtitle">Ingresa tu nombre de usuario para generar un token de recuperación.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="login-error">
                @Html.ValidationSummary(false, "", new { @class = "mb-0" })
            </div>
        }

        <form asp-action="RecuperarPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label asp-for="NombreUsuario" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                    <input asp-for="NombreUsuario" class="form-control has-icon" placeholder="Nombre de usuario" />
                </div>
                <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-login">
                <i class="fas fa-paper-plane me-2"></i>Generar token
            </button>
        </form>

        <div class="text-center mt-3">
            <a href="@Url.Action("Login","Cuenta")" class="small" style="color:var(--renacer-primary);">
                <i class="fas fa-arrow-left me-1"></i>Volver al login
            </a>
        </div>
    </div>
    <div class="login-footer">Sistema RENACER &copy; 2026</div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
