@model Sistema.RENACER.ViewModels.Usuarios.CambiarPasswordUsuarioViewModel
@{
    ViewData["Title"] = "Cambiar contraseña";
    Layout = "_Layout";
}

<div class="mb-3">
    <h2 class="page-title"><i class="fas fa-lock me-2"></i>Cambiar contraseña</h2>
    <p class="page-subtitle">Usuario: <strong>@Model.NombreUsuario</strong></p>
</div>

<div class="card-renacer" style="max-width:480px;">
    <div class="card-body p-4">
        <form asp-action="CambiarPassword" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="IdUsuario" type="hidden" />
            <input asp-for="NombreUsuario" type="hidden" />

            <div class="mb-3">
                <label asp-for="NuevaPassword" class="form-label"></label>
                <input asp-for="NuevaPassword" class="form-control" placeholder="Mínimo 8 caracteres" />
                <span asp-validation-for="NuevaPassword" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="ConfirmarPassword" class="form-label"></label>
                <input asp-for="ConfirmarPassword" class="form-control" />
                <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Guardar
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-1"></i>Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
