@model Sistema.RENACER.ViewModels.Usuarios.UsuarioListaViewModel
@{
    ViewData["Title"] = "Detalle de usuario";
    Layout = "_Layout";
}

<div class="mb-3">
    <h2 class="page-title"><i class="fas fa-user me-2"></i>Detalle de usuario</h2>
</div>

<div class="card-renacer" style="max-width:560px;">
    <div class="card-body p-4">
        <dl class="row">
            <dt class="col-sm-4">Nombre completo</dt>
            <dd class="col-sm-8">@Model.NombreCompleto</dd>

            <dt class="col-sm-4">Usuario</dt>
            <dd class="col-sm-8"><code>@Model.NombreUsuario</code></dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@(Model.Email ?? "—")</dd>

            <dt class="col-sm-4">Rol</dt>
            <dd class="col-sm-8">@Model.Rol</dd>

            <dt class="col-sm-4">Estado</dt>
            <dd class="col-sm-8">
                <span class="@(Model.Activo ? "badge-activo" : "badge-inactivo")">
                    @(Model.Activo ? "Activo" : "Inactivo")
                </span>
            </dd>

            <dt class="col-sm-4">Creado</dt>
            <dd class="col-sm-8">@Model.FechaCreacion.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Último acceso</dt>
            <dd class="col-sm-8">@(Model.UltimoAcceso?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")</dd>
        </dl>

        <div class="d-flex gap-2 mt-2">
            <a href="@Url.Action("Editar", new { id = Model.IdUsuario })" class="btn btn-primary">
                <i class="fas fa-edit me-1"></i>Editar
            </a>
            <a href="@Url.Action("Index")" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>
</div>
