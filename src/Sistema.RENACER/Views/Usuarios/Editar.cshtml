@model Sistema.RENACER.ViewModels.Usuarios.UsuarioEditarViewModel
@{
    ViewData["Title"] = "Editar usuario";
    Layout = "_Layout";
}

<div class="mb-3">
    <h2 class="page-title"><i class="fas fa-user-edit me-2"></i>Editar usuario</h2>
    <p class="page-subtitle">Usuario: <strong>@Model.NombreUsuario</strong></p>
</div>

<div class="card-renacer" style="max-width:680px;">
    <div class="card-body p-4">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="IdUsuario" type="hidden" />
            <input asp-for="NombreUsuario" type="hidden" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombres" class="form-label"></label>
                    <input asp-for="Nombres" class="form-control" />
                    <span asp-validation-for="Nombres" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Apellidos" class="form-label"></label>
                    <input asp-for="Apellidos" class="form-control" />
                    <span asp-validation-for="Apellidos" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="IdRol" class="form-label"></label>
                    <select asp-for="IdRol" asp-items="Model.Roles" class="form-select"></select>
                    <span asp-validation-for="IdRol" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Guardar cambios
                </button>
                <a href="@Url.Action("CambiarPassword", new { id = Model.IdUsuario })"
                   class="btn btn-outline-primary">
                    <i class="fas fa-lock me-1"></i>Cambiar contraseña
                </a>
                <a href="@Url.Action("Index")" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-1"></i>Volver
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
